export const propertyImageApi = {
  getImages: (propertyId) => api.get(`/properties/${propertyId}/images`),
  addImage: (propertyId, data) => api.post(`/properties/${propertyId}/images`, data),
  replaceImages: (propertyId, data) => api.put(`/properties/${propertyId}/images`, data),
  deleteImage: (propertyId, imageId) => api.delete(`/properties/${propertyId}/images/${imageId}`),
}

